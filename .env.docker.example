# Copy to .env.docker and adapt:
# cp .env.docker.example .env.docker

# Port exposed on the host (default 3000)
PORT=3000

# Supabase (required for cloud sync)
# These variables are also passed at BUILD time (NEXT_PUBLIC_*)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Optional: proxy for Ultimate Guitar import
UG_IMPORT_PROXY_URL=
