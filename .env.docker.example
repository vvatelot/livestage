# Copier vers .env.docker puis adapter :
# cp .env.docker.example .env.docker

# Port exposé sur l'hôte (défaut 3000)
PORT=3000

# Supabase (obligatoire pour la sync cloud)
# Ces variables sont aussi passées au BUILD (NEXT_PUBLIC_*)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Optionnel : proxy pour import Ultimate Guitar
UG_IMPORT_PROXY_URL=
